---
import { SITE } from '@/site.config';

const path = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home', deck: 'overview', icon: '⌂' },
  { href: '/ideas', label: 'Ideas', deck: 'field notes', icon: '◇' },
  { href: '/tags', label: 'Tags', deck: 'topic graph', icon: '#' },
  { href: '/archive', label: 'Archive', deck: 'timeline', icon: '▦' },
];

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE.title} home`}>
      <img class="brand-mark" src="/icons/icon-cyber.svg" alt="" width="40" height="40" />
      <span class="brand-copy">
        <strong>{SITE.title}</strong>
        <em>knowledge graph online</em>
      </span>
    </a>
    <nav aria-label="Main">
      <ul class="site-nav">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              <span class="site-nav__icon" aria-hidden="true">{item.icon}</span>
              <span class="site-nav__text">
                <strong>{item.label}</strong>
                <em>{item.deck}</em>
              </span>
            </a>
          </li>
        ))}
        <li>
          <a href="#header-search" class="no-print site-nav__search">
            <span class="site-nav__icon" aria-hidden="true">⌕</span>
            <span class="site-nav__text">
              <strong>Search</strong>
              <em>press /</em>
            </span>
          </a>
        </li>
      </ul>
    </nav>
    <div class="search-slot" id="header-search"></div>
  </div>
</header>
