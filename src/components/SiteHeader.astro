---
import { SITE } from '@/site.config';

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M19 4c-7.5 0-13 4.5-13 11 0 1.7.4 3.2 1 4.3.4-2.8 1.8-6.6 5.5-9.8-2.6 3.5-3.9 7-4.2 10C9.3 20.4 10.6 21 12 21c6 0 8-7.6 8-13 0-1.5-.3-2.9-1-4z"
            fill="currentColor"
          />
        </svg>
      </span>
      {SITE.title}
    </a>
    <nav aria-label="Main">
      <ul class="site-nav">
        <li>
          <a href="/ideas" aria-current={isActive('/ideas') ? 'page' : undefined}>
            Ideas
          </a>
        </li>
        <li>
          <a href="/tags" aria-current={isActive('/tags') ? 'page' : undefined}>
            Tags
          </a>
        </li>
        <li>
          <a href="/archive" aria-current={isActive('/archive') ? 'page' : undefined}>
            Archive
          </a>
        </li>
        <li>
          <a href="#header-search" class="no-print">
            Search <span class="kbd-hint">/</span>
          </a>
        </li>
      </ul>
    </nav>
    <div class="search-slot" id="header-search"></div>
  </div>
</header>
