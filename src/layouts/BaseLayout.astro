---
import '@/styles/global.css';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import Search from '@/components/Search.astro';
import WikiSidebar from '@/components/WikiSidebar.astro';
import { SITE } from '@/site.config';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  sidebar?: boolean;
}

const {
  title,
  description = SITE.description,
  wide = false,
  sidebar = true,
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const containerClass = wide ? 'container container--wide' : 'container';
const shellClass = sidebar ? 'site-shell site-shell--with-sidebar' : 'site-shell';
const path = Astro.url.pathname;
const appNavItems = [
  { href: '/', label: 'Home', icon: '⌂', active: path === '/' },
  { href: '/ideas', label: 'Ideas', icon: '◇', active: path.startsWith('/ideas') },
  { href: '/tags', label: 'Tags', icon: '#', active: path.startsWith('/tags') },
  { href: '/archive', label: 'Archive', icon: '▦', active: path.startsWith('/archive') },
  { href: '#header-search', label: 'Search', icon: '⌕', active: false },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f6f1e6" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#11160f" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Wiki" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" href="/icons/icon-cyber.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/icon-192.png" sizes="192x192" type="image/png" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter:ital,opsz,wght@0,14..32,400..800;1,14..32,400..800&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
  </head>
  <body>
    <SiteHeader />
    <section class="wiki-command-ribbon no-print" aria-label="Wiki quick map">
      <a href="/ideas"><span>◇</span><strong>Ideas</strong><em>living notes</em></a>
      <a href="/tags"><span>#</span><strong>Tags</strong><em>clusters</em></a>
      <a href="/archive"><span>▦</span><strong>Archive</strong><em>timeline</em></a>
      <a href="#header-search"><span>⌕</span><strong>Search</strong><em>recall</em></a>
    </section>
    <div class={shellClass}>
      {sidebar && <WikiSidebar />}
      <main>
        <div class={containerClass} data-pagefind-body>
          <slot />
        </div>
      </main>
    </div>
    <SiteFooter />
    <nav class="wiki-app-nav no-print" aria-label="Primary mobile navigation">
      {appNavItems.map((item) => (
        <a class="wiki-app-nav__link" href={item.href} aria-current={item.active ? 'page' : undefined}>
          <span class="wiki-app-nav__icon" aria-hidden="true">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
    <Search />
    <script is:inline src="/assets/tailnet-admin-visibility.js"></script>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
